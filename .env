# Environment variables for cold chain monitoring server
# Copy this file to .env and fill in your actual values

# Server port
PORT=3000

# MQTT Configuration
MQTT_BROKER=broker.emqx.io
MQTT_PORT=1883
MQTT_CLIENT_ID=esp32_backend

# MySQL Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_mysql_root_password_here
DB_NAME=coldchain